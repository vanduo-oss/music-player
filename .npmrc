# ═══════════════════════════════════════════════════════
# pnpm Security Configuration — @vanduo-oss/music-player
# ═══════════════════════════════════════════════════════

# ── Supply Chain Protection ──────────────────────────

# Block lifecycle scripts by default (pnpm v10+ default; explicit is better).
ignore-scripts=true

# Delay installing newly-published packages by 24 hours so the community has
# time to flag malicious versions before they reach us (Aikido Safe-Chain).
minimum-release-age=1440

# Refuse trust-level downgrades on updates (provenance/signature regressions).
trust-policy=no-downgrade

# Dependencies must come from the registry — no git/tarball exotic subdeps.
block-exotic-subdeps=true

# ── Determinism & Reproducibility ────────────────────

# Pin exact versions when adding/updating packages.
save-exact=true

# Strictly enforce peer dependency requirements.
strict-peer-dependencies=true

# ── Registry ─────────────────────────────────────────

registry=https://registry.npmjs.org/
